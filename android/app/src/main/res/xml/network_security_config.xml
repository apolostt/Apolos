<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Blocks plaintext HTTP for this app's own network clients (e.g. any
         future HTTPS calls). Does not affect other protocols the VPN tunnel
         handles directly, such as the plaintext DNS/UDP forwarding in
         ShieldVpnService. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
